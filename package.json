{
  "name": "smooth-vuebar",
  "version": "2.0.1",
  "description": "Vue 3 directive wrapper for smooth-scrollbar",
  "type": "module",
  "main": "./dist/smooth-vuebar.cjs",
  "module": "./dist/smooth-vuebar.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/smooth-vuebar.js",
      "require": "./dist/smooth-vuebar.cjs",
      "types": "./dist/index.d.ts"
    },
    "./default.css": "./src/default.css"
  },
  "files": [
    "dist",
    "src/default.css"
  ],
  "sideEffects": [
    "src/default.css"
  ],
  "scripts": {
    "build": "vite build",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run build && npm run test"
  },
  "peerDependencies": {
    "vue": "^3.2.0"
  },
  "dependencies": {
    "smooth-scrollbar": "^8.8.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.6.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9",
    "vue": "^3.5.39"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scaccogatto/smooth-vuebar.git"
  },
  "keywords": [
    "vue",
    "vue3",
    "smooth",
    "smooth-scroll",
    "scrollbar",
    "custom-scrollbar",
    "directive",
    "plugin",
    "typescript",
    "vite"
  ],
  "author": "Marco 'Gatto' Boffo",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/scaccogatto/smooth-vuebar/issues"
  },
  "homepage": "https://github.com/scaccogatto/smooth-vuebar#readme"
}
